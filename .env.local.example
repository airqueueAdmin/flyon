# Copy this file to .env.local and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/flight_platform
DB_USERNAME=flight
DB_PASSWORD=flight

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_API_TOKEN=your-admin-token

# ── RapidAPI (Skyscanner) ─────────────────────────────────────────────────────
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_ROUND_TRIP_BASE_URL=https://flights-sky.p.rapidapi.com/web/flights/search-roundtrip

# ── Duffel (optional, disabled by default) ────────────────────────────────────
# DUFFEL_ENABLED=true
# DUFFEL_API_KEY=your-duffel-api-key

# ── Kakao Login + Talk Message API ────────────────────────────────────────────
# Register this exact local redirect URI in Kakao Developers:
# http://localhost:8080/kakao-callback.html
KAKAO_ENABLED=true
KAKAO_PROVIDER=kakao-message-api
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_REDIRECT_URI=http://localhost:8080/kakao-callback.html
# Required if Kakao Developers has Client Secret enabled for the REST API key.
# KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ── Analytics (optional) ──────────────────────────────────────────────────────
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NAVER_ANALYTICS_ID=your-naver-analytics-id
