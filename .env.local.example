# Copy this file to .env.local and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/flight_platform
DB_USERNAME=flight
DB_PASSWORD=flight

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_API_TOKEN=your-admin-token

# ── RapidAPI (Skyscanner) ─────────────────────────────────────────────────────
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_ROUND_TRIP_BASE_URL=https://flights-sky.p.rapidapi.com/web/flights/search-roundtrip

# ── Duffel (optional, disabled by default) ────────────────────────────────────
# DUFFEL_ENABLED=true
# DUFFEL_API_KEY=your-duffel-api-key

# ── Kakao (optional, set KAKAO_ENABLED=false to disable) ──────────────────────
# KAKAO_API_KEY=your-ncp-sens-api-key
# KAKAO_API_SECRET=your-ncp-sens-api-secret
# KAKAO_SENDER_NUMBER=0212345678
# KAKAO_TEMPLATE_CODE=your-template-code
# KAKAO_SERVICE_ID=your-ncp-service-id
# KAKAO_PLUS_FRIEND_ID=your-plus-friend-id

# ── Analytics (optional) ──────────────────────────────────────────────────────
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NAVER_ANALYTICS_ID=your-naver-analytics-id
